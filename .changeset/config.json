{
	"$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
	"changelog": [
		"@savvy-web/silk/changesets/changelog",
		{
			"repo": "savvy-web/vitest",
			"packages": {
				"@savvy-web/vitest": {
					"additionalScopes": ["plugin/**"],
					"versionFiles": [
						{
							"glob": "plugin/.claude-plugin/plugin.json",
							"paths": ["$.version"]
						}
					]
				}
			}
		}
	],
	"commit": false,
	"access": "restricted",
	"baseBranch": "main",
	"updateInternalDependencies": "patch",
	"ignore": [],
	"privatePackages": {
		"tag": true,
		"version": true
	}
}
