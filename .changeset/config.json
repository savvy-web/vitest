{
	"$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
	"changelog": [
		"@savvy-web/changesets/changelog",
		{
			"repo": "savvy-web/vitest",
			"versionFiles": [
				{ "glob": "plugin/.claude-plugin/plugin.json", "paths": ["$.version"], "package": "@savvy-web/vitest" }
			]
		}
	],
	"commit": false,
	"access": "restricted",
	"baseBranch": "main",
	"updateInternalDependencies": "patch",
	"ignore": [],
	"privatePackages": {
		"tag": true,
		"version": true
	}
}
