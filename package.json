{
	"name": "savvy-web-vitest",
	"version": "0.0.0",
	"private": true,
	"description": "Vitest utility functions for Silk Suite deployment system",
	"homepage": "https://github.com/savvy-web/vitest#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/vitest/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/savvy-web/vitest.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run --coverage",
		"ci:version": "savvy-changesets version && biome format --write .",
		"commit:check": "savvy-commit check",
		"commit:init": "savvy-commit init",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped"
	},
	"devDependencies": {
		"@savvy-web/changesets": "^0.8.0",
		"@savvy-web/commitlint": "^0.6.0",
		"@savvy-web/lint-staged": "^1.0.0",
		"@savvy-web/rslib-builder": "^0.20.2",
		"@savvy-web/vitest": "workspace:*",
		"@vitest/coverage-v8": "^4.1.5",
		"vitest": "^4.1.5",
		"vitest-agent-reporter": "^1.3.0"
	},
	"packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.33.2",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "24.11.0",
				"onFail": "ignore"
			}
		]
	}
}
